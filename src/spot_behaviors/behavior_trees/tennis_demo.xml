<root main_tree_to_execute="MainTree">

  <tree ID="MainTree">

    <!-- STARTUP SEQUENCE -->
    <Sequence name="Startup">
      <TriggerService service_name="/spot_driver/power_on"/>
      <TriggerService service_name="/spot_driver/undock"/>
      <BinDetected/>
      <SetBlackboard output_key="bin_detected_once" value="true"/>
    </Sequence>

    <!-- POST-STARTUP GATE -->
    <Sequence name="PostStartupGate">
      <EqualTo input="{bin_detected_once}" value="true"/>

      <!-- HIGH-LEVEL BEHAVIOR -->
      <ReactiveFallback name="TopLevelSelector">

        <!-- ENTER BALL MODE -->
        <Sequence name="EnterBallMode">
          <BallDetected/>
          <SetBlackboard output_key="ball_mode_active" value="true"/>
        </Sequence>

        <!-- SURVEY ROUTINE -->
        <Sequence name="SurveyRoutine">
          <GoalUpdater topic="/survey_goal" output="survey_pose"/>
          <NavigateToPose goal="{survey_pose}"/>
          <WaitTime msec="500"/>
        </Sequence>

      </ReactiveFallback>

      <!-- BALL HANDLING -->
      <Sequence name="BallHandling">

        <EqualTo input="{ball_mode_active}" value="true"/>

        <WaitTime msec="200"/>
        <GoalUpdater topic="/ball_goal_pose" output="ball_pose"/>
        <NavigateToPose goal="{ball_pose}"/>

        <WaitTime msec="200"/>
        <GoalUpdater topic="/bin_goal_pose" output="bin_pose"/>
        <NavigateToPose goal="{bin_pose}"/>

        <SetBlackboard output_key="ball_mode_active" value="false"/>
      </Sequence>

    </Sequence>

  </tree>
</root>
